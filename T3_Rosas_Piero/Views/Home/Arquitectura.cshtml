@{
    ViewData["Title"] = "Libros de Arquitectura de Software";
}
<div class="container my-4">
    <div class="position-relative rounded overflow-hidden mb-5 shadow-sm" style="max-height: 400px;">
        <img src="https://images.unsplash.com/photo-1629654297299-c8506221ca97?auto=format&fit=crop&w=1200&q=80" class="w-100 h-100" style="object-fit: cover; object-position: center;" alt="Escritorio con libros de arquitectura de software">
        <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex align-items-center">
            <div class="container text-white ps-5">
                <h1 class="display-4 fw-bold mb-2"><i class="bi bi-diagram-3"></i> Arquitectura de Software</h1>
                <p class="lead">Los pilares y fundamentos que todo desarrollador senior debe dominar.</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="row g-0">
                   
                    <div class="col-md-8">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">Fundamentals of Software Architecture</h5>
                            <p class="card-text text-muted small">Autores: Mark Richards, Neal Ford</p>
                            <p class="card-text">Una guía integral sobre las decisiones de diseño de arquitectura, principios de ingeniería, efectividad y análisis de componentes modernos.</p>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light p-3">
                    <h6 class="fw-semibold mb-2">Video Análisis / Resumen:</h6>
                    <div class="ratio ratio-16x9">
                        <iframe src="https://www.youtube.com/embed/9nOhdooZuF0" title="Fundamentals of Software Architecture Review" allowfullscreen></iframe>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="row g-0">
                    <div class="col-md-8">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">Clean Architecture</h5>
                            <p class="card-text text-muted small">Autor: Robert C. Martin (Uncle Bob)</p>
                            <p class="card-text">Presenta las reglas universales de la arquitectura de software, ayudando a entender la separación de capas, fronteras lógicas y componentes.</p>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light p-3">
                    <h6 class="fw-semibold mb-2">Video Análisis / Resumen:</h6>
                    <div class="ratio ratio-16x9">
                        <iframe src="https://www.youtube.com/embed/Z7UFAozja2s" title="Clean Architecture Video" allowfullscreen></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>