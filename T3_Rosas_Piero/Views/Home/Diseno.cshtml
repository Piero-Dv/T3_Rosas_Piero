@{
    ViewData["Title"] = "Libros de Diseño de Software";
}

<div class="container my-4">
    <h2 class="text-success mb-4"><i class="bi bi-palette"></i> Libros de Diseño de Software</h2>
    <hr />

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="row g-0">
                    <div class="col-md-4 p-2 d-flex align-items-center justify-content-center">
                        <img src="https://images-na.ssl-images-amazon.com/images/I/81gtKoapHFL.jpg" class="img-fluid rounded" alt="Design Patterns" style="max-height: 200px;">
                    </div>
                    <div class="col-md-8">
                        <div class="card-body">
                            <h5 class="card-title">Design Patterns (Gang of Four)</h5>
                            <p class="card-text text-muted small">Autores: Erich Gamma, Richard Helm, Ralph Johnson, John Vlissides</p>
                            <p class="card-text">La biblia de los patrones de diseño orientados a objetos. Contiene las soluciones estándar a problemas comunes del desarrollo de software.</p>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light p-3">
                    <h6>Video Análisis / Resumen:</h6>
                    <div class="ratio ratio-16x9">
                        <iframe src="https://www.youtube.com/embed/v9ejT8FO-7I" title="Design Patterns Video" allowfullscreen></iframe>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>