@model T3_Rosas_Piero.Models.Libro

@{
    ViewData["Title"] = "Crear Libro";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3>Nuevo Libro</h3>
        </div>

        <div class="card-body">
            <form method="post" asp-action="Crear">

                <div class="mb-3">
                    <label asp-for="Titulo" class="form-label">Título</label>
                    <input asp-for="Titulo" class="form-control" placeholder="Ingrese el título del libro" />
                    <span asp-validation-for="Titulo" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Autor" class="form-label">Autor</label>
                    <input asp-for="Autor" class="form-control" placeholder="Ingrese el autor" />
                    <span asp-validation-for="Autor" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Editorial" class="form-label">Editorial</label>
                    <input asp-for="Editorial" class="form-control" placeholder="Ingrese la editorial" />
                    <span asp-validation-for="Editorial" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Tema" class="form-label">Tema / Género</label>
                    <input asp-for="Tema" class="form-control" placeholder="Ingrese el tema" />
                    <span asp-validation-for="Tema" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AnioPublicacion" class="form-label">Año de Publicación</label>
                    <input asp-for="AnioPublicacion" type="number" class="form-control" placeholder="Ej. 2026" />
                    <span asp-validation-for="AnioPublicacion" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Paginas" class="form-label">Páginas</label>
                    <input asp-for="Paginas" type="number" class="form-control" placeholder="Número de páginas" />
                    <span asp-validation-for="Paginas" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Material" class="form-label">Material</label>
                    <input asp-for="Material" class="form-control" placeholder="Ej. Tapa dura, rústica" />
                    <span asp-validation-for="Material" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Copias" class="form-label">Copias disponibles</label>
                    <input asp-for="Copias" class="form-control" placeholder="Número de copias" />
                    <span asp-validation-for="Copias" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Categoria" class="form-label">Categoría</label>
                    <input asp-for="Categoria" class="form-control" placeholder="Seleccione o ingrese la categoría" />
                    <span asp-validation-for="Categoria" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        Guardar Libro
                    </button>

                    <a asp-controller="Libro"
                       asp-action="Index"
                       class="btn btn-secondary">
                        Regresar
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}