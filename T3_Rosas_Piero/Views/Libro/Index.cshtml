@model IEnumerable<T3_Rosas_Piero.Models.Libro>
@{
    ViewData["Title"] = "Listado de Libros";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container pt-3">
    <div class="row pt-4 align-items-center">
        <div class="col-6">
            <h2 class="text-primary">Lista de Libros</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Libro" asp-action="Crear" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nuevo Libro
            </a>
        </div>
    </div>

    <br />

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped" style="width:100%">
                <thead>
                    <tr>
                        <th>Título</th>
                        <th>Autor</th>
                        <th>Editorial</th>
                        <th>Tema</th>
                        <th>Año</th>
                        <th>Páginas</th>
                        <th>Categoría</th>
                        <th>Copias</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Titulo</td>
                            <td>@item.Autor</td>
                            <td>@item.Editorial</td>
                            <td>@item.Tema</td>
                            <td>@item.AnioPublicacion</td>
                            <td>@item.Paginas</td>
                            <td>@item.Categoria</td>
                            <td>@item.Copias</td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-controller="Libro" asp-action="Editar" asp-route-id="@item.Id" class="btn btn-warning btn-sm mx-1">
                                        Editar
                                    </a>
                                    <a asp-controller="Libro" asp-action="Eliminar" asp-route-id="@item.Id" class="btn btn-danger btn-sm mx-1">
                                        Eliminar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-warning mt-3" role="alert">
            No hay registros de Libros actualmente.
        </div>
    }
</div>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}